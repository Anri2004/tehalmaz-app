{
  "expo": {
    "name": "Техалмаз",
    "slug": "tekhalmaz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ru.tekhalmaz.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Для прикрепления фото к заявке"
      }
    },
    "android": {
      "package": "ru.tekhalmaz.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": ["INTERNET"],
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Доступ к фото нужен, чтобы прикрепить их к заявке."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://functions.yandexcloud.net/d4efrcscfce1vugur7lr"
    }
  }
}
