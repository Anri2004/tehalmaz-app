{
  "expo": {
    "name": "Техалмаз",
    "slug": "tekhalmaz",
    "owner": "tekhalmaz-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ru.tekhalmaz.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Для прикрепления фото к заявке"
      }
    },
    "android": {
      "package": "ru.tekhalmaz.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Доступ к фото нужен, чтобы прикрепить их к заявке."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://functions.yandexcloud.net/d4efrcscfce1vugur7lr",
      "eas": {
        "projectId": "c0e2f266-5c66-4007-bd71-36dd0b83a007"
      }
    }
  }
}
